{
  "name": "a11ying-front",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "quality": "npm run check && npm run test:unit && npm run test:e2e && npm run test:a11y && npm run test:visual",
    "test": "npm run test:e2e",
    "test:e2e": "E2E_USE_MOCKS=true playwright test",
    "test:e2e:ui": "E2E_USE_MOCKS=true playwright test --ui",
    "test:e2e:headed": "E2E_USE_MOCKS=true playwright test --headed",
    "test:unit": "vitest run src/lib/payload.test.ts",
    "test:a11y": "E2E_USE_MOCKS=false npm run build && E2E_USE_MOCKS=false playwright test tests/axe-core.spec.ts",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:visual:update": "playwright test --config playwright.visual.config.ts --update-snapshots"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/atkinson-hyperlegible": "^5.3.0",
    "@fontsource/lato": "^5.3.0",
    "@fontsource/satisfy": "^5.3.0",
    "@tailwindcss/vite": "^4.3.3",
    "a11ying-ui": "github:calydia/a11ying-ui#v2.0.12",
    "astro": "^6.4.8",
    "astro-icon": "^1.1.5",
    "dayjs": "^1.11.21",
    "qs-esm": "^8.0.1",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "vite": "7.3.2",
    "yaml": "2.9.0"
  }
}
