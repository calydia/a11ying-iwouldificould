{
  "name": "a11ying-front",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:e2e": "E2E_USE_MOCKS=true playwright test",
    "test:e2e:ui": "E2E_USE_MOCKS=true playwright test --ui",
    "test:e2e:headed": "E2E_USE_MOCKS=true playwright test --headed",
    "test:a11y": "E2E_USE_MOCKS=false npm run build && E2E_USE_MOCKS=false playwright test tests/axe-core.spec.ts",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:visual:update": "playwright test --config playwright.visual.config.ts --update-snapshots"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/atkinson-hyperlegible": "^5.2.6",
    "@fontsource/lato": "^5.2.6",
    "@fontsource/satisfy": "^5.2.6",
    "@tailwindcss/vite": "^4.2.2",
    "a11ying-ui": "github:calydia/a11ying-ui#v2.0.3",
    "astro": "^6.1.5",
    "astro-icon": "^1.1.5",
    "dayjs": "^1.11.20",
    "qs-esm": "^8.0.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0"
  }
}
