  .demo-button-padding {
    @apply block w-6 h-6 p-1 bg-lt-blue-light dark:bg-blue-tory;
  }
  .demo-button-size-padding {
    @apply absolute w-6 h-6 rounded-full z-10 opacity-50 top-0 left-0 bg-black dark:bg-white;
  }

  .bg-gray {
    @apply bg-slate-300 dark:bg-slate-900;
  }

  .box-gradient {
    @apply max-w-xl mx-4 sm:mx-auto border-8 p-8 md:my-12 bg-lt-blue-light text-lt-gray self-start shadow-md;
    @apply dark:bg-dk-purple dark:text-dk-gray;
  }

  .box-bordered h2,
  .box-gradient h2 {
    @apply mt-0;
  }

  .box-bordered h2::before,
  .box-gradient h2::before {
