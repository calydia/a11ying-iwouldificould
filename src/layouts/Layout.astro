  /* Unlayered: overrides @layer utilities (flex-col) on desktop */
  @media (min-width: 768px) {
    #site-search {
      flex-direction: row;
      align-items: center;
      row-gap: 0.5rem;
      column-gap: 1.5rem;
    }
    #site-search input[type="text"] {
      max-width: 24rem;
