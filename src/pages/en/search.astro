---
import Layout from '../../layouts/Layout.astro';
import { SearchComponent } from 'a11ying-ui';
const wcagUrl = 'https://wcag.a11y.ing/';
---
<Layout title="Site search" locale="en" metaDescription="Use the search feature to search for the site content. The search provides results on both languages."
  engUrl="search" fiUrl="haku" currentUrl="search" currentSlug="search" alternateFi="fi/haku" alternateEn="en/search" type="search"
  >
  <div class="max-w-[1564px] mx-auto md:px-8-px">
    <div class="text-lt-gray dark:text-dk-gray py-2 px-4-px max-w-xl mx-auto md:py-6 md:px-8-px lg:max-w-4xl">
      <h1 id="skip-target">Site search</h1>
      <p class="mb-0">The search finds content from all A11ying with Sanna content.</p>
    </div>
    <SearchComponent client:load searchLabel="Search for content" searchButton="Search" searchResultLabel="results"
      searchNoResults="No results." searchMainHeading="Search results for:" searchLocale="en"
      searchSiteName="Site: " searchContentType="Content type: "
      payloadUrl={import.meta.env.PUBLIC_PAYLOAD_URL}
      defaultResultBaseUrl="/"
      resultBaseUrls={{ reqpages: wcagUrl, criteria: wcagUrl, guidelines: wcagUrl, principles: wcagUrl }}
    />
  </div>
</Layout>